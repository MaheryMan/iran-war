Options -Indexes
Options +FollowSymlinks
# ─── Activation du moteur de réécriture ──────────────────────────────────────
RewriteEngine On

# ─── Variables utiles ────────────────────────────────────────────────────────
# Détecte si on est derrière un proxy (utile en prod avec load balancer)
RewriteCond %{HTTP:X-Forwarded-Proto} =https
RewriteRule ^ - [E=HTTPS:on]


# ─── Fichiers et dossiers réels → pas de réécriture ─────────────────────────
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# ─── daty yyyy/mm/dd + slug _ id .html ny rewriting ────────────────────────────────────
RewriteRule ^([0-9]{4})/([0-9]{2})/([0-9]{2})/([_a-z0-9-]+)_([0-9]+)\.html$ pages/article.php?id=$5&slug=$4&date=$1-$2-$3 [L,QSA]

# ─── Front controller : tout vers index.php ──────────────────────────────────
RewriteRule ^ index.php [QSA,L]

# ─── Compression Gzip (deflate) ──────────────────────────────────────────────
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/xml
    AddOutputFilterByType DEFLATE text/css text/javascript
    AddOutputFilterByType DEFLATE application/javascript application/json
    AddOutputFilterByType DEFLATE image/svg+xml
</IfModule>

# ─── Cache navigateur ────────────────────────────────────────────────────────
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType image/jpeg           "access plus 1 month"
    ExpiresByType image/png            "access plus 1 month"
    ExpiresByType image/webp           "access plus 1 month"
    ExpiresByType image/svg+xml        "access plus 1 month"
    ExpiresByType image/x-icon         "access plus 1 year"
    ExpiresByType font/woff2           "access plus 1 year"
    ExpiresByType text/css             "access plus 1 month"
    ExpiresByType application/javascript "access plus 1 month"
    ExpiresByType text/html            "access plus 0 seconds"
</IfModule>

# ─── Headers de sécurité & SEO ───────────────────────────────────────────────
<IfModule mod_headers.c>
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set X-XSS-Protection "1; mode=block"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"

    # Cache long sur les assets statiques (fingerprinting recommandé en prod)
    <FilesMatch "\.(css|js|woff|woff2|ttf|eot|png|jpg|jpeg|gif|webp|svg|ico)$">
        Header set Cache-Control "public, max-age=2592000, immutable"
    </FilesMatch>

    # Pas de cache sur les pages PHP
    <FilesMatch "\.php$">
        Header set Cache-Control "no-store, no-cache, must-revalidate, max-age=0"
        Header set Pragma "no-cache"
    </FilesMatch>

    # Suppression de la signature serveur
    Header unset Server
    Header always unset X-Powered-By
</IfModule>

# ─── Protection des fichiers sensibles ───────────────────────────────────────
<FilesMatch "(^\.htaccess|\.env|composer\.(json|lock)|package\.json)$">
    Require all denied
</FilesMatch>

# ─── Désactiver les ETags (évite les problèmes de cache entre serveurs) ───────
FileETag None
Header unset ETag
